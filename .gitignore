# --------------- 必忽略（你的项目已出现）---------------
# IDEA配置目录（自动生成，无需提交）
.idea/
# IDEA项目配置文件（与.idea配套）
JavaAlgorithmPractice.iml
# Maven/Gradle构建目录（编译产物，可重新生成）
target/

# --------------- 补充忽略（Java项目通用，避免后续冗余）---------------
# 编译产生的class文件
*.class
# 打包产物（jar、war包）
*.jar
*.war
*.ear
# 编译临时文件
bin/
out/
# 日志文件
*.log
logs/
# 系统临时文件
.DS_Store  # Mac系统
Thumbs.db  # Windows系统
# maven相关临时文件
.m2/
# IDE相关临时文件
*.iml
*.iws
*.ipr
.idea/workspace.xml
.idea/libraries/
# 本地配置文件（如数据库配置，不提交到远程）
*.properties
*.yml
# 测试相关临时文件
test-output/
# 其他临时文件
tmp/
temp/